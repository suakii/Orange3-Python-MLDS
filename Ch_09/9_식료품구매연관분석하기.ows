		<properties node_id="5" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\x9e\x00\x00\x00&lt;\x00\x00\x05f\x00\x00\x03\r\x00\x00\x01\x9f\x00\x00\x00Z\x00\x00\x05e\x00\x00\x03\x0c\x00\x00\x00\x00\x00\x00\x00\x00\x06\xab\x00\x00\x01\x9f\x00\x00\x00Z\x00\x00\x05e\x00\x00\x03\x0c', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import numpy as np\nfrom Orange.data import Table, Domain, ContinuousVariable, DiscreteVariable\n\ndomain = Domain([ContinuousVariable("age"),\n                 ContinuousVariable("height"),\n                 DiscreteVariable("gender", values=("M", "F"))])\narr = np.array([\n  [25, 186, 0],\n  [30, 164, 1]])\nout_data = Table.from_numpy(domain, arr)\n', 'filename': None}], 'scriptText': 'import Orange.data.pandas_compat as p\n# [오류 방지 1] 입력 데이터가 비어있는지 확인\nif in_data is not None:\n    # 1. Orange 데이터를 판다스로 변환\n    df = p.pd.concat(in_data.to_pandas_dfs(), axis=1)\n    # 2. 원-핫 인코딩\n    one_hot = p.pd.get_dummies(df[\'itemDescription\'])\n    # 3. 필요한 정보 결합\n    df_combined = df[[\'Member_number\', \'Date\']].join(one_hot)\n    # 4. 장바구니 그룹화 및 합계\n    transaction = df_combined.groupby([\'Member_number\', \'Date\']).sum()\n    # 5. 이진화 (구매 여부 0, 1)\n    transaction[transaction &gt;= 1] = 1\n    # [오류 방지 2] 인덱스 재설정\n    # Orange 출력 시 Multi-Index나 복잡한 인덱스는 오류를 일으킬 수 있습니다.\n    # reset_index()를 통해 인덱스를 일반 컬럼으로 빼줍니다.\n    transaction_final = transaction.reset_index()\n    # 6. Orange 전용 처리 (0을 공백으로)\n    # 인덱스를 리셋했으므로, 상품 컬럼들만 선택해서 replace를 적용합니다.\n    transaction_final = transaction_final.replace(0, "")\n    # 7. 최종 데이터 변환 및 출력\n    out_data = p.table_from_frame(transaction_final)\nelse:\n    # 데이터가 없을 경우 빈 테이블 방지\n    out_data = None', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x01\x98\x00\x00\x00U\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
